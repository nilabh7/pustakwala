# ============================================================
# Pustakwala — Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# Database
DATABASE_URL=
DB_NAME=
DB_USER=
DB_PASSWORD=change_this_strong_password
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# JWT Secrets — generate with: openssl rand -base64 48
JWT_SECRET=change_this_jwt_secret_minimum_32_chars_long
JWT_REFRESH_SECRET=change_this_refresh_secret_minimum_32_chars

# App
FRONTEND_URL=http://localhost
EMAIL_VERIFICATION_ENFORCED_AT=2026-04-04T00:00:00.000Z

# Email (Resend API)
EMAIL_ENABLED=true
EMAIL_VERIFY_ON_STARTUP=true
EMAIL_FAIL_FAST=true
EMAIL_PROVIDER=resend_api
RESEND_API_KEY=re_xxx
EMAIL_FROM=Pustakwala <onboarding@resend.dev>
EMAIL_REPLY_TO=support@pustakwala.com
EMAIL_OTP_EXPIRY_MINUTES=10
