# ============================================================
# Pustakwala — Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# Database
DB_NAME=pustakwala
DB_USER=postgres
DB_PASSWORD=change_this_strong_password

# JWT Secrets — generate with: openssl rand -base64 48
JWT_SECRET=change_this_jwt_secret_minimum_32_chars_long
JWT_REFRESH_SECRET=change_this_refresh_secret_minimum_32_chars

# App
FRONTEND_URL=http://localhost

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM=Pustakwala <noreply@pustakwala.com>
