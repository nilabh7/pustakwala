NODE_ENV=production
PORT=8080
API_PREFIX=/api/v1

# Supabase Postgres
# Prefer the Session Pooler or Direct Connection string from Supabase > Connect.
DATABASE_URL=postgresql://postgres:YOUR_SUPABASE_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Frontend
FRONTEND_URL=https://your-vercel-app.vercel.app

# Email via Resend API
EMAIL_ENABLED=true
EMAIL_VERIFY_ON_STARTUP=true
EMAIL_FAIL_FAST=true
EMAIL_PROVIDER=resend_api
RESEND_API_KEY=re_xxx
EMAIL_FROM=Pustakwala <onboarding@resend.dev>
EMAIL_REPLY_TO=support@pustakwala.com

# App
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=uploads
PLATFORM_FEE_PERCENT=5
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
