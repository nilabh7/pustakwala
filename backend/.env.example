# Server
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pustakwala
DB_USER=postgres
DB_PASSWORD=nilabh7
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT
JWT_SECRET=12345678901234567890123456789012
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=12345678901234567890123456789011
JWT_REFRESH_EXPIRES_IN=30d

# Email (SMTP)
# Production recommendation: use a transactional email provider or SMTP relay.
EMAIL_ENABLED=false
EMAIL_VERIFY_ON_STARTUP=true
EMAIL_FAIL_FAST=false
EMAIL_FROM=Pustakwala <noreply@your-domain.com>
EMAIL_REPLY_TO=support@your-domain.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password_or_token
SMTP_MAX_CONNECTIONS=5
SMTP_MAX_MESSAGES=100
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
SMTP_TLS_REJECT_UNAUTHORIZED=true

# Frontend URL (for CORS & email links)
FRONTEND_URL=http://localhost:4200

# File Upload
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=uploads

# Platform Fee (percentage)
PLATFORM_FEE_PERCENT=5

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
