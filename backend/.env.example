# Server
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=change_this_strong_password
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT
JWT_SECRET=change_this_jwt_secret_minimum_32_chars_long
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_refresh_secret_minimum_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# Email
EMAIL_ENABLED=false
EMAIL_VERIFY_ON_STARTUP=true
EMAIL_FAIL_FAST=false
EMAIL_PROVIDER=resend_api
EMAIL_FROM=Pustakwala <noreply@your-domain.com>
EMAIL_REPLY_TO=support@your-domain.com
RESEND_API_KEY=re_xxx
RESEND_API_URL=https://api.resend.com/emails
EMAIL_OTP_EXPIRY_MINUTES=10

# Frontend URL (for CORS & email links)
FRONTEND_URL=http://localhost:4200
EMAIL_VERIFICATION_ENFORCED_AT=2026-04-04T00:00:00.000Z

# File Upload
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=uploads

# Platform Fee (percentage)
PLATFORM_FEE_PERCENT=5

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
